# =============================================================================
# Agent-Stream-echobot — Git ignore
# =============================================================================
# Safe to commit: source code, .env.example, Dockerfile, docker-compose.yml
# Never commit: .env (API keys), logs/, local caches
# =============================================================================

# --- Secrets & local env (NEVER push) ---
.env
.env.local
.env.*.local
!.env.example

credentials.json
*credentials*.json
*service-account*
secrets/
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/
pip-wheel-metadata/
*.manifest
*.spec

# Virtual environments
venv/
.venv/
env/
ENV/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- Logs & runtime ---
logs/
*.log
*.log.*
*.pid
*.sock

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Cursor (local agent state — do not push)
.cursor/

# --- Docker / deploy artifacts (local only) ---
docker-compose.override.yml
*.local.yml

# --- ngrok / tunnels ---
ngrok
ngrok.exe
ngrok.yml
*.tgz

# --- Temp / scratch ---
*.tmp
*.temp
tmp/
temp/
.cache/
