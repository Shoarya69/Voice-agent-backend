# =============================================================================
# AI Voice Agent - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your real API keys:
#
#   cp .env.example .env
#
# Never commit your real `.env` file to git.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI - used as the "brain" of the agent (decides what to say)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.6
# Kept short so replies are fast to generate and fast to speak on a call.
OPENAI_MAX_TOKENS=45

# System prompt that defines the assistant's personality/behaviour
SYSTEM_PROMPT=You are a friendly Hindi/Hinglish voice assistant on a live phone call. Reply in simple Hindi/Hinglish unless the caller clearly asks for another language. Use the shortest possible words. One short sentence only. No lists or filler.

# Optional reply length caps (defaults: target 10 words, hard max 30 words)
REPLY_WORD_TARGET=10
REPLY_WORD_MAX=30

# -----------------------------------------------------------------------------
# ElevenLabs - used for Speech-to-Text (STT) and Text-to-Speech (TTS)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=el-your-elevenlabs-api-key-here

# Voice to use for TTS. Default below is ElevenLabs' public "Rachel" voice.
# Find more voice IDs at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# TTS model - eleven_turbo_v2_5 / eleven_flash_v2_5 are fastest (recommended for calls)
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5

# STT model
ELEVENLABS_STT_MODEL=scribe_v1

# Optional ISO-639-1 language code to force STT language (hi = Hindi).
# Keep blank only if you truly need automatic multilingual detection.
ELEVENLABS_STT_LANGUAGE=hi

ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# -----------------------------------------------------------------------------
# Voice agent / conversation behaviour
# -----------------------------------------------------------------------------
# Seconds of caller silence before the agent processes what was said and replies
SILENCE_THRESHOLD=1.5

# Minimum amount of buffered caller audio (in ms) required before it is sent to STT
MIN_AUDIO_MS_TO_PROCESS=500

# WebRTC VAD aggressiveness: 0 least aggressive, 3 most aggressive.
VAD_MODE=2

# Calibrate the per-call noise floor from initial/silent frames.
NOISE_CALIBRATION_MS=800
NOISE_FLOOR_MULTIPLIER=5.0

# Minimum dynamic RMS threshold. Actual threshold is max(this, noise_floor * multiplier).
DYNAMIC_RMS_MIN=400

# Hard cap on how high the adaptive noise floor may drift. Without this, a
# burst of echoed bot audio during calibration can permanently raise the
# threshold so high that real speech afterwards is never detected.
NOISE_FLOOR_MAX_RMS=600

# Require this much continuous VAD-confirmed speech before voice start.
VAD_START_MS=150

# End the turn after this much VAD/RMS-confirmed silence.
VAD_END_SILENCE_MS=800

# Require at least this much VAD-confirmed speech before sending audio to STT.
MIN_VAD_SPEECH_MS=250

# Tolerate brief dips below the speech threshold while a speech candidate is
# building, instead of throwing away the candidate audio (this was clipping
# the first syllable of real words - see logs showing repeated
# "speech_candidate_reset" right before a confirmed VOICE START).
VAD_CANDIDATE_TOLERANCE_MS=120

# Ignore inbound audio and pause noise-floor calibration for this long after
# the bot stops talking, since telephony lines commonly echo the bot's own
# voice back into the inbound stream.
ECHO_GUARD_MS=250

# Reject low-confidence STT results.
STT_MIN_AVG_WORD_CONFIDENCE=0.35
STT_MIN_LANGUAGE_PROBABILITY=0.45

# TTS volume multiplier. Keep at 1.0 for maximum clarity; only lower this
# (e.g. 0.8) if you hear clipping/distortion on your specific phone line.
TTS_VOLUME=1.0

# Greeting spoken automatically when a call connects
ENABLE_WELCOME_MESSAGE=true
WELCOME_MESSAGE=Hi! I'm your AI assistant. How can I help you today?

# Number of user+assistant turn pairs kept in conversation memory
MAX_CONVERSATION_TURNS=20

# Allow the caller to interrupt (barge-in) while the bot is speaking
ENABLE_BARGE_IN=false

# -----------------------------------------------------------------------------
# Voice pipeline provider (switch without code changes)
# -----------------------------------------------------------------------------
# compound         — production default: ElevenLabs STT → OpenAI → ElevenLabs TTS
# openai_realtime  — OpenAI Realtime API (speech-to-speech, lower latency)
VOICE_PIPELINE=compound

# OpenAI Realtime settings (only used when VOICE_PIPELINE=openai_realtime)
# GA model — do not use deprecated gpt-4o-realtime-preview-* identifiers.
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# OPENAI_REALTIME_BASE_URL=wss://api.openai.com/v1
# OPENAI_REALTIME_VOICE=alloy
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# OPENAI_REALTIME_VAD_THRESHOLD=0.5
# OPENAI_REALTIME_PREFIX_PADDING_MS=300
# OPENAI_REALTIME_SILENCE_DURATION_MS=500

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=INFO

# Separate plain-HTTP port for Exotel's telephony webhooks (Status Callback /
# conversation applet URL configured in the Exotel Flow for a number). These
# are relayed to Lovable's voice-status / voice-conversation hooks. Point
# Exotel's callback URLs at:
#   http://<this-server>:<WEBHOOK_PORT>/exotel/status
#   http://<this-server>:<WEBHOOK_PORT>/exotel/conversation
WEBHOOK_PORT=8081

# Prewarm MoontechPro agent + greeting caches during ring (Exotel status
# callback on /exotel/status). Set false only if status callbacks are not
# wired or you prefer HTTP prewarm only.
PREWARM_ON_EXOTEL_STATUS=true

# Optional explicit prewarm (MoontechPro can POST during voice-inbound setup):
#   POST http://<this-server>:<WEBHOOK_PORT>/voicebot/prewarm
#   Authorization: Bearer <LOVABLE_API_SECRET>
#   Body: {"number": "<exophone>"}  OR  {"token": "<agent-token>"}
# Returns 202-style {"status":"accepted"} immediately; work runs in background.

# -----------------------------------------------------------------------------
# Concurrency / capacity (6 vCPU / 12 GB VPS — target ~100–150 concurrent calls)
# -----------------------------------------------------------------------------
MAX_CONCURRENT_SESSIONS=150
MAX_CONCURRENT_STT=80
MAX_CONCURRENT_TTS=80
VAD_WORKER_THREADS=4
MAX_TURN_AUDIO_MS=30000
ENABLE_VAD_FRAME_LOGS=false
VAD_FRAME_LOG_EVERY=500
HTTP_MAX_CONNECTIONS=200
HTTP_MAX_KEEPALIVE=60
HTTP_KEEPALIVE_EXPIRY=30

# Audio sample rate used on the Exotel stream (raw/slin). Keep at 8000 unless
# your Exotel applet is configured for a different sample rate.
SAMPLE_RATE=8000

# Dashboard (optional, see dashboard.py)
DASHBOARD_PORT=5001

# -----------------------------------------------------------------------------
# Supabase — direct agent reads (replaces Moontech HTTP GET on live-call path)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co

# Preferred (server-only, bypasses RLS):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Inbound agent resolution uses RPC get_inbound_agent_bundle (single call).
# Alternative if you only have the publishable key (requires RPC execute grant):
# SUPABASE_ANON_KEY=your-publishable-anon-key

# Moontech base URL — used ONLY for cold greeting audio synth fallback
# (when greeting_audio_base64 is missing in ai_agents). Write APIs still use LOVABLE_APP_URL.
MOONTECH_BASE_URL=https://www.moontechpro.com

# -----------------------------------------------------------------------------
# Lovable control plane - per-agent config lookup + call logging
# -----------------------------------------------------------------------------
# Base URL of your Lovable app (no trailing slash needed).
LOVABLE_APP_URL=https://www.moontechpro.com

# Fallback auth only, sent as an Authorization: Bearer header on call-log
# requests for backwards compatibility. The primary auth for agent lookup is
# the per-agent `token` query param on the Exotel WSS URL
# (wss://your-server/?token=<per-agent-token>), NOT this secret.
LOVABLE_API_SECRET=
#
# Notes on the Lovable <-> Exotel wiring (no agent_id sent anywhere - Lovable
# always resolves the agent itself):
#   - Inbound answer URL: configured once per Exotel phone number, directly
#     in Exotel's Flow/App Bazaar, pointing straight at Lovable
#     (https://www.moontechpro.com/api/public/hooks/voice-inbound?provider=exotel&pn_id=...&t=...).
#     This server is NEVER involved in that hop - it's an Exotel-only,
#     HMAC-verified telephony webhook that returns TwiML, not JSON. Lovable
#     mints a per-call `token` there and embeds it in the <Stream url="...
#     ?token=..."> TwiML, which is how Exotel then dials this server's WSS
#     endpoint with the token already in the URL.
#   - If a call reaches this server's WSS endpoint WITHOUT a `token`, that
#     means the Exotel Flow's Stream URL is misconfigured - this server logs
#     an error, speaks the fallback greeting, and closes. It does NOT try to
#     look up the agent any other way (no `?number=` lookup exists).
#   - Status callback / conversation applet URLs in the Exotel Flow should
#     point at THIS server (see WEBHOOK_PORT above); it relays the raw
#     Exotel form fields (CallSid/From/To/CallStatus/CallDuration/
#     RecordingUrl) to Lovable's voice-status / voice-conversation hooks.
#   - Channel release: handled by Supabase (voice-status updates ai_calls.outcome;
#     PostgreSQL trigger ai_calls_release_channel_trg releases the channel).
